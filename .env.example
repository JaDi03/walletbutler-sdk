# Venice AI Dev Cook-Off configuration

# Private key for the Agent to use x402 authentication (Sign-in with X / SIWE)
# This account will be used to generate signatures for the Venice API
AGENT_CHAT_PRIVATE_KEY=0x...

# Public RPC URLs used ONLY by the MetaMask SDK for internal state parsing (e.g., nonces).
# Note: Venice RPCs cannot be used here because the MetaMask viem client does not support injecting dynamic x402 SIWE headers.
# The Agent itself DOES use Venice RPCs (via src/venice.ts) for all deterministic blockchain reads.
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
RPC_URL_BASE_MAINNET=https://mainnet.base.org

# Optional: Webhook URL for receiving 1Shot Relayer callback statuses
# This is typically used in production (e.g. Vercel) instead of local polling
WEBHOOK_URL=https://your-domain.vercel.app/api/webhook/1shot
